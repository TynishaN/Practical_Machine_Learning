library(caret)
library(ggplot2)
library(ggplot2)
install.packages("rlang")
install.packages(c("rlang", "ggplot2","caret"))
library(ggplot2)
library(caret)
library(randomForest)
library(dplyr)
trainingData <- read.csv(
"pml-training.csv",
na.strings = c("NA", "", "#DIV/0!")
)
testingData <- read.csv(
"pml-testing.csv",
na.strings = c("NA", "", "#DIV/0!")
)
# View the dimensions of the datasets
dim(trainingData)
dim(testingData)
# Display the structure of the training dataset
str(trainingData)
# View summary statistics
summary(trainingData)
# Remove variables that contain missing values
trainingData <- trainingData[, colSums(is.na(trainingData)) == 0]
testingData <- testingData[, colSums(is.na(testingData)) == 0]
# Remove the first seven columns because they contain
# identification information rather than useful predictors
trainingData <- trainingData[, -(1:7)]
testingData <- testingData[, -(1:7)]
# Verify the new dimensions
dim(trainingData)
dim(testingData)
# Set a seed so the results can be reproduced
set.seed(123)
# Create a 70% training sample
inTrain <- createDataPartition(
trainingData$classe,
p = 0.70,
list = FALSE
)
trainSet <- trainingData[inTrain, ]
validationSet <- trainingData[-inTrain, ]
# Use 5-fold cross validation to estimate model performance
fitControl <- trainControl(
method = "cv",
number = 5
)
# Train the prediction model
set.seed(123)
rfModel <- train(
classe ~ .,
data = trainSet,
method = "rf",
trControl = fitControl
)
library(ggplot2)
library(caret)
library(randomForest)
library(dplyr)
trainingData <- read.csv(
"pml-training.csv",
na.strings = c("NA", "", "#DIV/0!")
)
testingData <- read.csv(
"pml-testing.csv",
na.strings = c("NA", "", "#DIV/0!")
)
# View the dimensions of the datasets
dim(trainingData)
dim(testingData)
# Display the structure of the training dataset
str(trainingData)
# View summary statistics
summary(trainingData)
# Remove variables that contain missing values
trainingData <- trainingData[, colSums(is.na(trainingData)) == 0]
testingData <- testingData[, colSums(is.na(testingData)) == 0]
# Remove the first seven columns because they contain
# identification information rather than useful predictors
trainingData <- trainingData[, -(1:7)]
testingData <- testingData[, -(1:7)]
# Verify the new dimensions
dim(trainingData)
dim(testingData)
# Set a seed so the results can be reproduced
set.seed(123)
# Create a 70% training sample
inTrain <- createDataPartition(
trainingData$classe,
p = 0.70,
list = FALSE
)
trainSet <- trainingData[inTrain, ]
validationSet <- trainingData[-inTrain, ]
# Use 5-fold cross validation to estimate model performance
fitControl <- trainControl(
method = "cv",
number = 5
)
# Train the prediction model
set.seed(123)
rfModel <- train(
classe ~ .,
data = trainSet,
method = "rf",
trControl = fitControl
)
# Display model information
print(rfModel)
# Predict the validation dataset
validationPredictions <- predict(
rfModel,
validationSet
)
# Display the confusion matrix
confusionMatrix(
validationPredictions,
validationSet$classe
)
str(validationPredictions)
str(validationSet$classe)
levels(validationPredictions)
levels(validationSet$classe)
# Remove variables that contain missing values
trainingData <- trainingData[, colSums(is.na(trainingData)) == 0]
testingData <- testingData[, colSums(is.na(testingData)) == 0]
# Remove the first seven columns because they contain
# identification information rather than useful predictors
trainingData <- trainingData[, -(1:7)]
testingData <- testingData[, -(1:7)]
# Verify the new dimensions
dim(trainingData)
dim(testingData)
# Convert the response variable to a factor
trainingData$classe <- factor(trainingData$classe)
# Set a seed so the results can be reproduced
set.seed(123)
# Create a 70% training sample
inTrain <- createDataPartition(
trainingData$classe,
p = 0.70,
list = FALSE
)
trainSet <- trainingData[inTrain, ]
validationSet <- trainingData[-inTrain, ]
# Use 5-fold cross validation to estimate model performance
fitControl <- trainControl(
method = "cv",
number = 5
)
# Train the prediction model
set.seed(123)
rfModel <- train(
classe ~ .,
data = trainSet,
method = "rf",
trControl = fitControl
)
# Display model information
print(rfModel)
# Predict the validation dataset
validationPredictions <- predict(
rfModel,
validationSet
)
# Display the confusion matrix
confusionMatrix(
validationPredictions,
validationSet$classe
)
# Store the confusion matrix
results <- confusionMatrix(
validationPredictions,
validationSet$classe
)
# Display model accuracy
results$overall["Accuracy"]
# Calculate out-of-sample error
1 - results$overall["Accuracy"]
# Predict the unseen testing dataset
finalPredictions <- predict(
rfModel,
testingData
)
# Display the predictions
print(finalPredictions)
# Save predictions to a CSV file
write.csv(
finalPredictions,
"Course_Project_Predictions.csv",
row.names = FALSE
)
getwd()
source("~/Practical machine learning code check.R")
